{
    "name": "psc-acme/manager-inventory",
    "description": "Package manager-inventory for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ManagerInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "ramsey/uuid": "^4.0",
        "nesbot/carbon": "^2.72",
        "predis/predis": "^2.0",
        "doctrine/orm": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}